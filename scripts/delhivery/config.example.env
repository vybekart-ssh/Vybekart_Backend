# Delhivery + Razorpay — local / Render env template
# Copy relevant lines into Vybekart_Backend/.env or Render Dashboard.

# --- Delhivery (production live token) ---
DELHIVERY_ENV=prod
DELHIVERY_API_TOKEN_PROD=
DELHIVERY_CLIENT_NAME=
DELHIVERY_PICKUP_LOCATION=
DELHIVERY_AUTO_PICKUP_REQUEST=true
DELHIVERY_PICKUP_TIME=15:00:00

# --- Razorpay ---
# Use rzp_test_* keys for payment testing; rzp_live_* for production.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Public backend URL (Android app + webhooks)
API_PUBLIC_URL=https://vybekart-backend.onrender.com
