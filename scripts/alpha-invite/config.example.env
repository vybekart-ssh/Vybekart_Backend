# Copy these into VybeKart-Backend/.env (or export in shell) for alpha invite sends.

RESEND_API_KEY=re_your_key_here
MAIL_FROM=VybeKart <noreply@vybekart.co.in>

# Optional — queue sends via Resend. All scheduled times are IST (Asia/Kolkata, +05:30).
# RESEND_SCHEDULED_AT=tomorrow at 4pm IST
# RESEND_SCHEDULED_AT=2026-04-18T16:00:00+05:30

# Optional — defaults are sensible if omitted
# REGISTRATIONS_CSV=./scripts/alpha-invite/registrations.csv
# Optional: add a suffix like "(v2)" while testing to avoid Gmail threading ("Show quoted text")
ALPHA_SUBJECT_SUFFIX=
ALPHA_DRIVE_URL=https://drive.google.com/drive/folders/1DUobwSc-sBDoijr5RA6OpH_T5oXS9tPp?usp=sharing
# Optional: separate seller onboarding URL (falls back to ALPHA_DRIVE_URL if unset)
ALPHA_SELLER_URL=
ALPHA_WEBSITE_URL=https://vybekart.co.in

# Header logo: direct HTTPS URL; must return Content-Type image/* (Supabase: public bucket + correct path/case).
# If unset, header is text-only. In Gmail use “Display images” for noreply@vybekart.co.in if blocked.
# Script appends ?v=1 for cache busting; set ALPHA_LOGO_NO_CACHE_BUST=true only if that breaks your host.
ALPHA_LOGO_URL=https://axcsnealmdadjryogrnl.supabase.co/storage/v1/object/public/Vybekart/vybekart_logo.png

# Optional hero image (shown in email body)
# Prefer ALPHA_HERO_IMAGE_URL (loads directly, like the logo).
ALPHA_HERO_IMAGE_URL=https://axcsnealmdadjryogrnl.supabase.co/storage/v1/object/public/Vybekart/vybekartPoster.png

ALPHA_REPLY_TO=support@vybekart.co.in
ALPHA_SUPPORT_EMAIL=support@vybekart.co.in
ALPHA_SUPPORT_PHONE=
ALPHA_COMPANY_LEGAL_NAME=VybeKart
ALPHA_TERMS_URL=https://vybekart.co.in/terms
ALPHA_PRIVACY_URL=https://vybekart.co.in/privacy

# DRY_RUN=true
# ALPHA_SEND_DELAY_MS=700
# ALPHA_SEND_LOG=./scripts/alpha-invite/send-log.jsonl

# Bulk sends (OTP notice vs alpha APK invite) — see scripts/email/send-registrations-mail.ts
# REGISTRATIONS_MAIL=otp
# REGISTRATION_OTP=796300
# REGISTRATIONS_SEND_LOG=./scripts/email/send-log.jsonl

# --- DLT OTP SMS (Fast2SMS) — set after telecom + Fast2SMS DLT Manager approval ---
# OTP_ENV=production
# FAST2SMS_API_KEY=
# FAST2SMS_ROUTE=dlt
# FAST2SMS_SENDER_ID=VYBEKT
# ANDROID_SMS_APP_HASH=           # 11-char release app hash (static line in DLT templates)
# FAST2SMS_DLT_MSG_ID_LOGIN=      # Fast2SMS DLT Manager message_id (not telecom template_id)
# FAST2SMS_DLT_MSG_ID_BUYER_SIGNUP=
# FAST2SMS_DLT_MSG_ID_SELLER_SIGNUP=
# FAST2SMS_DLT_MSG_ID_FORGOT_PASSWORD=
