# Copy these into VybeKart-Backend/.env (or export in shell) for alpha invite sends.

RESEND_API_KEY=re_your_key_here
MAIL_FROM=VybeKart <noreply@vybekart.co.in>

# Optional — defaults are sensible if omitted
# REGISTRATIONS_CSV=./scripts/alpha-invite/registrations.csv
ALPHA_DRIVE_URL=https://drive.google.com/drive/folders/1DUobwSc-sBDoijr5RA6OpH_T5oXS9tPp?usp=sharing
ALPHA_WEBSITE_URL=https://vybekart.co.in

# Header logo: direct HTTPS URL; must return Content-Type image/* (Supabase: public bucket + correct path/case).
# If unset, header is text-only. In Gmail use “Display images” for noreply@vybekart.co.in if blocked.
# Script appends ?v=1 for cache busting; set ALPHA_LOGO_NO_CACHE_BUST=true only if that breaks your host.
ALPHA_LOGO_URL=https://axcsnealmdadjryogrnl.supabase.co/storage/v1/object/public/Vybekart/vybekart_logo.png

ALPHA_REPLY_TO=support@vybekart.co.in
ALPHA_SUPPORT_EMAIL=support@vybekart.co.in
ALPHA_SUPPORT_PHONE=
ALPHA_COMPANY_LEGAL_NAME=VybeKart
ALPHA_TERMS_URL=https://vybekart.co.in/terms
ALPHA_PRIVACY_URL=https://vybekart.co.in/privacy

# DRY_RUN=true
# ALPHA_SEND_DELAY_MS=700
# ALPHA_SEND_LOG=./scripts/alpha-invite/send-log.jsonl
