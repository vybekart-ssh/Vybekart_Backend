INSERT INTO public."Faq" ("id", "question", "answer", "sortOrder")
SELECT gen_random_uuid(), f.question, f.answer, f.sortOrder
FROM faqs f
WHERE NOT EXISTS (
  SELECT 1 FROM public."Faq" x WHERE x."question" = f.question
);

COMMIT;